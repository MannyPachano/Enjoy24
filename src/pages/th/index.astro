---
import Layout from '../../layouts/Layout.astro';
import HomePage from '../../components/HomePage.astro';

const origin =
  Astro.site?.origin ?? new URL(import.meta.env.SITE ?? 'https://enjoy24.netlify.app').origin;

const localBusinessLd = {
  '@context': 'https://schema.org',
  '@type': 'CannabisStore',
  name: 'Enjoy 24h',
  description:
    'ร้านกัญชา กาแฟสด และมุม PlayStation 5 เปิด 24 ชั่วโมงทุกวันที่ราไวย์ ภูเก็ต กัญชาคุณภาพ บรรยากาศชิล',
  url: `${origin}/th/`,
  image: [`${origin}/og.webp`],
  telephone: '+66993594534',
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: '+66993594534',
    contactType: 'customer service',
    url: 'https://wa.me/66993594534',
    availableLanguage: ['English', 'Thai'],
  },
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Q8R9+H3V, Rawai',
    addressLocality: 'Rawai',
    addressRegion: 'Phuket',
    addressCountry: 'TH',
  },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
      opens: '00:00',
      closes: '24:00',
    },
  ],
  sameAs: ['https://maps.google.com/?q=Q8R9%2BH3V+Rawai+Phuket', 'https://wa.me/66993594534'],
};
---

<Layout
  locale="th"
  ogLocale="th_TH"
  title="Enjoy 24h — กัญชา · กาแฟ · เกม · เปิด 24 ชั่วโมง · ราไวย์ ภูเก็ต"
  description="ร้านกัญชา กาแฟสด และมุม PlayStation 5 เปิด 24 ชั่วโมงทุกวันที่ราไวย์ ภูเก็ต กัญชาคุณภาพ บรรยากาศชิล"
  ogImageAlt="ร้าน Enjoy 24h — กัญชา กาแฟ และเลานจ์ที่ราไวย์ ภูเก็ต"
>
  <script type="application/ld+json" slot="jsonld" set:html={JSON.stringify(localBusinessLd)} />
  <HomePage locale="th" />
</Layout>
