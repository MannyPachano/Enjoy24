---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Lost in the smoke — Enjoy 24h"
  description="That page doesn't exist. Head back home."
  noindex
>
  <div class="page-404">
    <div class="page-404__bg" aria-hidden="true"></div>

    <div class="page-404__wrap">
      <svg class="page-404__leaf"><use href="#leaf-icon"></use></svg>
      <div class="eyebrow">Page not found</div>
      <div class="code">404</div>
      <h1>Lost in the<br /><span class="accent">smoke.</span></h1>
      <p>
        That page doesn't exist — or maybe it never did. Either way, the door's still open back at the shop.
      </p>
      <div class="ctas">
        <a href="/" class="btn btn--primary">Take me home →</a>
        <a href="/#visit" class="btn btn--ghost">Visit the shop</a>
      </div>
    </div>
  </div>
</Layout>
